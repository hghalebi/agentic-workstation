# OpenClaw production-style Ubuntu server profile.
INSTALL_BASE=1
INSTALL_SERVER_BASE=1
INSTALL_DOCKER=1
INSTALL_RUNTIMES=1
INSTALL_RUST_SERVER_TOOLS=1
INSTALL_VERSION_MANAGERS=0
INSTALL_GIT_HELPERS=1
INSTALL_AGENT_CLIS=1
INSTALL_BROWSER_TOOLS=0
INSTALL_CLOUD_CLIS=1
INSTALL_TERMINAL_TOOLS=1
INSTALL_FACTORY_TOOLS=0
INSTALL_SECURITY_TOOLS=0
INSTALL_LOCAL_MODEL_RUNTIME=0
INSTALL_ONEPASSWORD=1
INSTALL_HARNESS=0
INSTALL_OPENCLAW_LAYOUT=1
INSTALL_OPENTELEMETRY=1
INSTALL_NEON_SUPPORT=1
INSTALL_HETZNER_S3=1
INSTALL_ONEPASSWORD_SSH=1
AUTO_CONFIG=1

# Dotfiles are profile-scoped and optional outside this profile.
DOTFILES_REPO=https://github.com/hghalebi/dotfiles
DOTFILES_TARGET=/root/.dotfiles
DOTFILES_RUN_INSTALL=0

# Server defaults.
OPENCLAW_ENABLE_UFW=1
