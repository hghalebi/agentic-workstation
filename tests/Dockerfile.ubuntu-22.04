FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y sudo git curl ca-certificates shellcheck shfmt jq bats

WORKDIR /repo
COPY . .

RUN bash -n install-agentic-tools.sh scripts/*.sh cloud/*.sh
RUN shellcheck install-agentic-tools.sh scripts/*.sh cloud/*.sh
RUN shfmt -i 2 -ci -d install-agentic-tools.sh scripts/*.sh cloud/*.sh
RUN bats tests/unit

ARG RUN_INSTALL=0
ARG PROFILE=minimal
RUN if [ "$RUN_INSTALL" = "1" ]; then \
      SKIP_BROWSER_TOOLS=1 SKIP_AUTO_CONFIG=1 ./install-agentic-tools.sh --profile "$PROFILE" --no-doctor; \
      ./scripts/doctor.sh --profile "$PROFILE" --json; \
    fi
